---
import '@fontsource-variable/cormorant';
import '@fontsource/beth-ellen';
import '../styles/global.css';
import settings from '../lib/settings';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import PaintAccents from '../components/PaintAccents.astro';
import {
  defaultLocale,
  localeMeta,
  locales,
  localizePath,
  pickLocalized,
  switchLocalePath,
  useTranslations,
  type Locale,
} from '../i18n';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  /** Immagine per le anteprime social (percorso relativo o assoluto). */
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  /** Dati strutturati schema.org (JSON-LD) per motori di ricerca e AI. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { locale, title, description, ogImage, ogType = 'website', schema } = Astro.props;
const t = useTranslations(locale);
const meta = localeMeta[locale];
const pageTitle = title ? `${title} — ${settings.artistName}` : `${settings.artistName} — ${pickLocalized(settings.taglines, locale)}`;
const pageDescription = description || pickLocalized(settings.taglines, locale);
const bio = pickLocalized(settings.bios, locale);
const year = new Date().getFullYear();

const site = Astro.site ?? new URL('https://boleon.it');
const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, site);
const alternates = locales.map((l) => ({
  locale: l,
  hreflang: localeMeta[l].lang,
  href: new URL(switchLocalePath(currentPath, locale, l), site),
}));
const xDefault = new URL(switchLocalePath(currentPath, locale, defaultLocale), site);
const ogImageUrl = ogImage ? new URL(ogImage, site) : undefined;
---

<!doctype html>
<html lang={meta.lang} dir={meta.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <meta property="og:site_name" content={settings.artistName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={meta.og} />
    {alternates
      .filter((alt) => alt.locale !== locale)
      .map((alt) => <meta property="og:locale:alternate" content={localeMeta[alt.locale].og} />)}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <script is:inline define:vars={{ currentLocale: locale, allLocales: locales, defaultLocale }}>
      // Primo accesso della sessione: rispetta la lingua scelta in precedenza
      // (localStorage, impostata dallo switcher) o quella del browser, saltando
      // sulla stessa pagina nella lingua giusta. Guardia anti-loop in sessionStorage.
      try {
        if (!sessionStorage.getItem('boleon-lang-checked')) {
          sessionStorage.setItem('boleon-lang-checked', '1');
          var target = localStorage.getItem('boleon-lang');
          if (allLocales.indexOf(target) < 0) {
            target = null;
            var wanted = navigator.languages || [navigator.language || ''];
            for (var i = 0; i < wanted.length && !target; i++) {
              var code = String(wanted[i]).toLowerCase().split('-')[0];
              if (allLocales.indexOf(code) >= 0) target = code;
            }
          }
          if (target && target !== currentLocale) {
            var path = location.pathname;
            if (currentLocale !== defaultLocale) {
              path = path.replace(new RegExp('^/' + currentLocale + '(?=/|$)'), '') || '/';
            }
            if (target !== defaultLocale) {
              path = '/' + target + (path === '/' ? '' : path);
            }
            location.replace(path + location.search + location.hash);
          }
        }
      } catch (e) {
        /* storage disabilitato: resta nella lingua corrente */
      }
    </script>
  </head>
  <body class="relative flex min-h-screen flex-col antialiased">
    <PaintAccents />
    <header class="sticky top-0 z-40 border-b border-neutral-200 bg-paper/90 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-5">
        <a
          href={localizePath(locale, '/')}
          class="font-serif text-2xl font-semibold tracking-[0.35em] uppercase"
        >
          {settings.artistName}
        </a>
        <nav class="flex items-center gap-5 sm:gap-7">
          <a
            href={localizePath(locale, '/')}
            class="hidden text-xs tracking-widest uppercase opacity-70 transition hover:opacity-100 sm:block"
          >
            {t('nav.works')}
          </a>
          <a
            href={localizePath(locale, '/galleria')}
            class="hidden text-xs tracking-widest uppercase opacity-70 transition hover:opacity-100 sm:block"
          >
            {t('nav.gallery')}
          </a>
          <a
            href={localizePath(locale, '/contatto')}
            class="hidden text-xs tracking-widest uppercase opacity-70 transition hover:opacity-100 sm:block"
          >
            {t('nav.contact')}
          </a>
          <a
            href={localizePath(locale, '/carrello')}
            class="relative flex items-center gap-1.5 text-xs tracking-widest uppercase opacity-70 transition hover:opacity-100"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M5 8h14l-1.2 11.2a1.5 1.5 0 0 1-1.5 1.3H7.7a1.5 1.5 0 0 1-1.5-1.3L5 8Z"></path>
              <path d="M8.5 8V6.5a3.5 3.5 0 0 1 7 0V8"></path>
            </svg>
            <span class="hidden sm:inline">{t('nav.cart')}</span>
            <span
              data-cart-count
              class="absolute -top-2 -end-2 hidden size-4.5 items-center justify-center rounded-full bg-accent text-[0.65rem] font-semibold text-white sm:static sm:size-auto sm:rounded-none sm:bg-transparent sm:text-ink"
            ></span>
          </a>
          <LanguageSwitcher locale={locale} />
        </nav>
      </div>
    </header>

    <main class="relative z-10 mx-auto w-full max-w-6xl flex-1 px-5 pt-10 pb-20">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-neutral-200 bg-paper">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 py-12 sm:grid-cols-3">
        <div>
          <p class="font-serif text-lg tracking-[0.3em] uppercase">{settings.artistName}</p>
          {bio && <p class="mt-3 max-w-prose text-sm leading-relaxed opacity-70">{bio}</p>}
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase opacity-60">{t('footer.contact')}</p>
          {
            settings.contactEmail && (
              <a href={`mailto:${settings.contactEmail}`} class="mt-3 block text-sm underline-offset-4 hover:underline">
                {settings.contactEmail}
              </a>
            )
          }
          <a
            href={localizePath(locale, '/contatto')}
            class="mt-2 block text-sm underline-offset-4 hover:underline"
          >
            {t('contact.title')}
          </a>
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase opacity-60">{t('footer.follow')}</p>
          <div class="mt-3 flex flex-col gap-1 text-sm">
            {settings.instagram && <a href={settings.instagram} rel="noopener" target="_blank" class="underline-offset-4 hover:underline">Instagram</a>}
            {settings.facebook && <a href={settings.facebook} rel="noopener" target="_blank" class="underline-offset-4 hover:underline">Facebook</a>}
          </div>
        </div>
      </div>
      <div class="border-t border-neutral-100 py-4 text-center text-xs opacity-50">
        © {year} {settings.artistName} · {t('footer.rights')}
      </div>
    </footer>

    <script>
      import { cartCount } from '../scripts/cart';

      function render(count: number) {
        document.querySelectorAll('[data-cart-count]').forEach((el) => {
          el.textContent = count > 0 ? String(count) : '';
          el.classList.toggle('hidden', count === 0);
          el.classList.toggle('flex', count > 0);
        });
      }
      render(cartCount());
      window.addEventListener('cart:updated', (e) => render((e as CustomEvent).detail.count));
    </script>
  </body>
</html>
