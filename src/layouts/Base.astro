---
import '../styles/global.css';
import settings from '../content/settings.json';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { localeMeta, localizePath, pickLocalized, useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = useTranslations(locale);
const meta = localeMeta[locale];
const pageTitle = title ? `${title} — ${settings.artistName}` : `${settings.artistName} — ${pickLocalized(settings.taglines, locale)}`;
const pageDescription = description || pickLocalized(settings.taglines, locale);
const bio = pickLocalized(settings.bios, locale);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={meta.lang} dir={meta.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="flex min-h-screen flex-col antialiased">
    <header class="sticky top-0 z-40 border-b border-neutral-200 bg-paper/90 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-5">
        <a
          href={localizePath(locale, '/')}
          class="font-serif text-2xl font-semibold tracking-[0.35em] uppercase"
        >
          {settings.artistName}
        </a>
        <nav class="flex items-center gap-5 sm:gap-7">
          <a
            href={localizePath(locale, '/')}
            class="hidden text-xs tracking-widest uppercase opacity-70 transition hover:opacity-100 sm:block"
          >
            {t('nav.works')}
          </a>
          <a
            href={localizePath(locale, '/carrello')}
            class="relative flex items-center gap-1.5 text-xs tracking-widest uppercase opacity-70 transition hover:opacity-100"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M5 8h14l-1.2 11.2a1.5 1.5 0 0 1-1.5 1.3H7.7a1.5 1.5 0 0 1-1.5-1.3L5 8Z"></path>
              <path d="M8.5 8V6.5a3.5 3.5 0 0 1 7 0V8"></path>
            </svg>
            <span class="hidden sm:inline">{t('nav.cart')}</span>
            <span
              data-cart-count
              class="absolute -top-2 -end-2 hidden size-4.5 items-center justify-center rounded-full bg-accent text-[0.65rem] font-semibold text-white sm:static sm:size-auto sm:rounded-none sm:bg-transparent sm:text-ink"
            ></span>
          </a>
          <LanguageSwitcher locale={locale} />
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-5 pt-10 pb-20">
      <slot />
    </main>

    <footer class="border-t border-neutral-200">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 py-12 sm:grid-cols-3">
        <div>
          <p class="font-serif text-lg tracking-[0.3em] uppercase">{settings.artistName}</p>
          {bio && <p class="mt-3 max-w-prose text-sm leading-relaxed opacity-70">{bio}</p>}
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase opacity-60">{t('footer.contact')}</p>
          {
            settings.contactEmail && (
              <a href={`mailto:${settings.contactEmail}`} class="mt-3 block text-sm underline-offset-4 hover:underline">
                {settings.contactEmail}
              </a>
            )
          }
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase opacity-60">{t('footer.follow')}</p>
          <div class="mt-3 flex flex-col gap-1 text-sm">
            {settings.instagram && <a href={settings.instagram} rel="noopener" target="_blank" class="underline-offset-4 hover:underline">Instagram</a>}
            {settings.facebook && <a href={settings.facebook} rel="noopener" target="_blank" class="underline-offset-4 hover:underline">Facebook</a>}
          </div>
        </div>
      </div>
      <div class="border-t border-neutral-100 py-4 text-center text-xs opacity-50">
        © {year} {settings.artistName} · {t('footer.rights')}
      </div>
    </footer>

    <script>
      import { cartCount } from '../scripts/cart';

      function render(count: number) {
        document.querySelectorAll('[data-cart-count]').forEach((el) => {
          el.textContent = count > 0 ? String(count) : '';
          el.classList.toggle('hidden', count === 0);
          el.classList.toggle('flex', count > 0);
        });
      }
      render(cartCount());
      window.addEventListener('cart:updated', (e) => render((e as CustomEvent).detail.count));
    </script>
  </body>
</html>
