---
import '../styles/global.css';
import settings from '../content/settings.json';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import {
  defaultLocale,
  localeMeta,
  locales,
  localizePath,
  pickLocalized,
  switchLocalePath,
  useTranslations,
  type Locale,
} from '../i18n';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = useTranslations(locale);
const meta = localeMeta[locale];
const pageTitle = title ? `${title} — ${settings.artistName}` : `${settings.artistName} — ${pickLocalized(settings.taglines, locale)}`;
const pageDescription = description || pickLocalized(settings.taglines, locale);
const bio = pickLocalized(settings.bios, locale);
const year = new Date().getFullYear();
const siteBase = Astro.site ?? Astro.url;
const alternates = locales.map((l) => ({
  hreflang: localeMeta[l].lang,
  href: new URL(switchLocalePath(Astro.url.pathname, locale, l), siteBase).href,
}));
---

<!doctype html>
<html lang={meta.lang} dir={meta.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(switchLocalePath(Astro.url.pathname, locale, defaultLocale), siteBase).href}
    />
    <title>{pageTitle}</title>
    <script is:inline define:vars={{ currentLocale: locale, allLocales: locales, defaultLocale }}>
      // First visit of the session: honour the saved language choice, or the
      // browser language, by jumping to the same page in that language.
      try {
        if (!sessionStorage.getItem('boleon-lang-checked')) {
          sessionStorage.setItem('boleon-lang-checked', '1');
          var target = localStorage.getItem('boleon-lang');
          if (allLocales.indexOf(target) < 0) {
            target = null;
            var wanted = navigator.languages || [navigator.language || ''];
            for (var i = 0; i < wanted.length && !target; i++) {
              var code = String(wanted[i]).toLowerCase().split('-')[0];
              if (allLocales.indexOf(code) >= 0) target = code;
            }
          }
          if (target && target !== currentLocale) {
            var path = location.pathname;
            if (currentLocale !== defaultLocale) {
              path = path.replace(new RegExp('^/' + currentLocale + '(?=/|$)'), '') || '/';
            }
            if (target !== defaultLocale) {
              path = '/' + target + (path === '/' ? '' : path);
            }
            location.replace(path + location.search + location.hash);
          }
        }
      } catch (e) {
        /* storage disabled: keep the current language */
      }
    </script>
  </head>
  <body class="flex min-h-screen flex-col antialiased">
    <header class="sticky top-0 z-40 border-b border-neutral-200 bg-paper/90 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-5">
        <a
          href={localizePath(locale, '/')}
          class="font-serif text-2xl font-semibold tracking-[0.35em] uppercase"
        >
          {settings.artistName}
        </a>
        <nav class="flex items-center gap-5 sm:gap-7">
          <a
            href={localizePath(locale, '/')}
            class="hidden text-xs tracking-[0.2em] uppercase opacity-70 transition hover:opacity-100 sm:block"
          >
            {t('nav.works')}
          </a>
          <a
            href={localizePath(locale, '/carrello')}
            class="relative flex items-center gap-1.5 text-xs tracking-[0.2em] uppercase opacity-70 transition hover:opacity-100"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M5 8h14l-1.2 11.2a1.5 1.5 0 0 1-1.5 1.3H7.7a1.5 1.5 0 0 1-1.5-1.3L5 8Z"></path>
              <path d="M8.5 8V6.5a3.5 3.5 0 0 1 7 0V8"></path>
            </svg>
            <span class="hidden sm:inline">{t('nav.cart')}</span>
            <span
              data-cart-count
              class="absolute -top-2 -end-2 hidden size-4.5 items-center justify-center rounded-full bg-accent text-[0.65rem] font-semibold text-white sm:static sm:size-auto sm:rounded-none sm:bg-transparent sm:text-ink"
            ></span>
          </a>
          <LanguageSwitcher locale={locale} />
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-5 pt-10 pb-24">
      <slot />
    </main>

    <footer class="border-t border-neutral-200 bg-neutral-50/60">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-3">
        <div>
          <p class="font-serif text-xl font-semibold tracking-[0.3em] uppercase">{settings.artistName}</p>
          {bio && <p class="mt-4 max-w-prose text-sm leading-relaxed opacity-70">{bio}</p>}
        </div>
        <div>
          <p class="text-[0.65rem] font-semibold tracking-[0.25em] uppercase opacity-60">{t('footer.contact')}</p>
          {
            settings.contactEmail && (
              <a href={`mailto:${settings.contactEmail}`} class="mt-4 block text-sm underline-offset-4 hover:underline">
                {settings.contactEmail}
              </a>
            )
          }
        </div>
        <div>
          <p class="text-[0.65rem] font-semibold tracking-[0.25em] uppercase opacity-60">{t('footer.follow')}</p>
          <div class="mt-4 flex flex-col gap-1.5 text-sm">
            {settings.instagram && <a href={settings.instagram} rel="noopener" target="_blank" class="underline-offset-4 hover:underline">Instagram</a>}
            {settings.facebook && <a href={settings.facebook} rel="noopener" target="_blank" class="underline-offset-4 hover:underline">Facebook</a>}
          </div>
        </div>
      </div>
      <div class="border-t border-neutral-100 py-5 text-center text-xs opacity-50">
        © {year} {settings.artistName} · {t('footer.rights')}
      </div>
    </footer>

    <script>
      import { cartCount } from '../scripts/cart';

      function render(count: number) {
        document.querySelectorAll('[data-cart-count]').forEach((el) => {
          el.textContent = count > 0 ? String(count) : '';
          el.classList.toggle('hidden', count === 0);
          el.classList.toggle('flex', count > 0);
        });
      }
      render(cartCount());
      window.addEventListener('cart:updated', (e) => render((e as CustomEvent).detail.count));
    </script>
  </body>
</html>
