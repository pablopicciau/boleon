---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArtworkCard from '../ArtworkCard.astro';
import settings from '../../content/settings.json';
import { sortArtworks } from '../../lib/artworks';
import { pickLocalized, useTranslations, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const artworks = sortArtworks(await getCollection('artworks'));
const featured = artworks.filter((a) => a.data.featured);
const tagline = pickLocalized(settings.taglines, locale);
const bio = pickLocalized(settings.bios, locale);
---

<Base locale={locale}>
  <section class="py-14 text-center sm:py-24">
    <h1 class="font-serif text-5xl font-medium tracking-[0.22em] uppercase sm:text-7xl">
      {settings.artistName}
    </h1>
    <span class="mx-auto mt-8 block h-px w-16 bg-accent"></span>
    {
      tagline && (
        <p class="mx-auto mt-8 max-w-xl font-serif text-xl leading-relaxed italic opacity-70 sm:text-2xl">
          {tagline}
        </p>
      )
    }
  </section>

  {
    featured.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-8 text-[0.65rem] font-semibold tracking-[0.3em] uppercase opacity-60">
          {t('home.featured')}
        </h2>
        <div class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((artwork) => (
            <ArtworkCard artwork={artwork} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  <section class="mt-24">
    <h2 class="mb-8 text-[0.65rem] font-semibold tracking-[0.3em] uppercase opacity-60">
      {t('home.allWorks')}
    </h2>
    <div class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
      {artworks.map((artwork) => <ArtworkCard artwork={artwork} locale={locale} />)}
    </div>
  </section>

  {
    bio && (
      <section class="mt-28 grid gap-6 border-t border-neutral-200 pt-14 sm:grid-cols-3 sm:gap-10">
        <h2 class="text-[0.65rem] font-semibold tracking-[0.3em] uppercase opacity-60">
          {t('home.about')}
        </h2>
        <p class="font-serif text-2xl leading-relaxed font-medium opacity-90 sm:col-span-2 sm:text-3xl">
          {bio}
        </p>
      </section>
    )
  }
</Base>
