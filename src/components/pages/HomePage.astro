---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArtworkCard from '../ArtworkCard.astro';
import HeroSpotlight from '../HeroSpotlight.astro';
import settings from '../../lib/settings';
import heroFallback from '../../assets/quadri/opera-03.jpg';
import { heroImagesByName } from '../../lib/heroImages';
import { sortArtworks } from '../../lib/artworks';
import { localizePath, pickLocalized, useTranslations, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const artworks = sortArtworks(await getCollection('artworks'));

// Sfondi hero: se l'opzione "Usa le foto delle opere dello store" è attiva
// ruotano le copertine delle opere in catalogo; altrimenti le immagini scelte
// a mano da Keystatic; fallback a un quadro fisso se non c'è nulla.
const useArtworkImages = (settings as { useArtworkImages?: boolean }).useArtworkImages ?? false;
const configuredNames = ((settings as { heroImages?: string[] }).heroImages ?? [])
  .map((p) => p.split('/').pop() ?? '')
  .filter((name) => name in heroImagesByName);
const artworkCovers = artworks.map((a) => a.data.images[0]);
const heroImages =
  useArtworkImages && artworkCovers.length > 0
    ? artworkCovers
    : configuredNames.length > 0
      ? configuredNames.map((name) => heroImagesByName[name])
      : [heroFallback];
const featured = artworks.filter((a) => a.data.featured);
const tagline = pickLocalized(settings.taglines, locale);
const bio = pickLocalized(settings.bios, locale);
const description = [tagline, bio].filter(Boolean).join(' — ');

const site = Astro.site ?? new URL('https://boleon.it');
const sameAs = [settings.instagram, settings.facebook].filter(Boolean);
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: settings.artistName,
    url: site.href,
    description: tagline,
    inLanguage: ['it', 'en', 'es', 'fr', 'zh-Hans', 'hi', 'ar'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: settings.artistName,
    url: site.href,
    description: bio || tagline,
    jobTitle: 'Artist',
    ...(settings.contactEmail ? { email: `mailto:${settings.contactEmail}` } : {}),
    ...(sameAs.length ? { sameAs } : {}),
  },
];
---

<Base locale={locale} description={description} schema={schema}>
  <HeroSpotlight locale={locale} images={heroImages} />

  {
    featured.length > 0 && (
      <section id="opere" class="mt-16 scroll-mt-24">
        <h2 class="mb-8 text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
          {t('home.featured')}
        </h2>
        <div class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((artwork) => (
            <ArtworkCard artwork={artwork} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  <section id={featured.length === 0 ? 'opere' : undefined} class="mt-20 scroll-mt-24">
    <h2 class="mb-8 text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
      {t('home.allWorks')}
    </h2>
    <div class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
      {artworks.map((artwork) => <ArtworkCard artwork={artwork} locale={locale} />)}
    </div>
  </section>

  <div class="mt-20 text-center">
    <a
      href={localizePath(locale, '/galleria')}
      class="inline-block rounded-full bg-accent px-8 py-3.5 text-sm font-medium tracking-wide text-white uppercase transition-all hover:scale-[1.03] hover:bg-[#6f1f33] hover:shadow-lg hover:shadow-accent/30 active:scale-95"
    >
      {t('home.moreWorks')}
    </a>
  </div>
</Base>
