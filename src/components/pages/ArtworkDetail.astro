---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import settings from '../../lib/settings';
import {
  catalogEntries,
  collectionNumber,
  isBaseAvailable,
  isInquiryOnly,
  maxQty,
  printFormatsFor,
  printPrice,
  sortArtworks,
  PRINT_ID_SEPARATOR,
  type Artwork,
} from '../../lib/artworks';
import {
  formatPrice,
  localizePath,
  pickLocalized,
  useTranslations,
  type Locale,
} from '../../i18n';

interface Props {
  locale: Locale;
  artwork: Artwork;
}

const { locale, artwork } = Astro.props;
const t = useTranslations(locale);
const available = isBaseAvailable(artwork);
const max = maxQty(artwork);
const isPrint = artwork.data.kind === 'print';
const displayTitle = pickLocalized(artwork.data.titles, locale) || artwork.data.title;
const inquiryOnly = isInquiryOnly(artwork);
const inquiryOriginalMessage = t('inquiry.defaultMessage', { title: displayTitle });
const inquiryInfoMessage = t('inquiry.infoMessage', { title: displayTitle });
const description = pickLocalized(artwork.data.descriptions, locale);
const unavailableLabel = t(isPrint ? 'artwork.soldOut' : 'artwork.sold');
const printMaterials = pickLocalized(
  (settings as { printMaterials?: Record<string, string | null> }).printMaterials,
  locale
);

// Stampe: formati standard offerti da quest'opera, con prezzo carta/tela
const printFormats = printFormatsFor(artwork);
const cover = artwork.data.images[0];
// Proporzioni del dipinto (dalla foto di copertina), per l'avviso e l'anteprima
const imageRatio = cover.width / cover.height;
const printData = {
  slug: artwork.id,
  separator: PRINT_ID_SEPARATOR,
  imageRatio,
  borders: [0, 2, 3, 5],
  // Unità di misura iniziale: pollici per il pubblico anglofono, cm per gli altri
  defaultUnit: locale === 'en' ? 'in' : 'cm',
  lang: locale,
  formats: printFormats.map((f) => {
    const fmtRatio = Math.max(f.width, f.height) / Math.min(f.width, f.height);
    const imgRatio = Math.max(imageRatio, 1 / imageRatio);
    return {
      id: f.id,
      label: f.label,
      // "A4", "A3"… davanti alle misure; gli altri formati sono solo misure
      name: f.group === 'a' ? f.label.split('·')[0].trim() : '',
      group: f.group ?? 'eu',
      width: f.width,
      height: f.height,
      prices: {
        paper: printPrice(artwork, f, 'paper'),
        canvas: printPrice(artwork, f, 'canvas'),
      },
      priceLabels: {
        paper: formatPrice(printPrice(artwork, f, 'paper'), locale),
        canvas: formatPrice(printPrice(artwork, f, 'canvas'), locale),
      },
      ratioMismatch: Math.abs(fmtRatio - imgRatio) / imgRatio > 0.02,
    };
  }),
};
// Il formato preselezionato è il più economico, così il prezzo mostrato
// all'apertura coincide con il "da …" delle card della galleria
const defaultFormat = [...printData.formats].sort((a, b) => a.prices.paper - b.prices.paper)[0];

// "N° 2 · C. Notturni": numero dell'opera nella sua prima collezione
const firstCollection = artwork.data.collections[0];
const [allArtworks, allCollections] = await Promise.all([
  getCollection('artworks'),
  getCollection('collections'),
]);
let collectionLine: string | null = null;
if (firstCollection) {
  const collectionEntry = allCollections.find((c) => c.id === firstCollection);
  const n = collectionNumber(allArtworks, artwork, firstCollection);
  if (collectionEntry && n) {
    collectionLine = t('artwork.collectionLine', {
      n,
      name: pickLocalized(collectionEntry.data.names, locale) || collectionEntry.data.name,
    });
  }
}

// "Potrebbero piacerti anche": prima i più venduti, poi le altre opere
// (mescolate lato client a ogni visita)
const others = sortArtworks(allArtworks.filter((a) => a.id !== artwork.id));
const alsoLike = [
  ...others.filter((a) => a.data.bestseller),
  ...others.filter((a) => !a.data.bestseller),
].slice(0, 8);

const site = Astro.site ?? new URL('https://boleon.it');
const canonical = new URL(Astro.url.pathname, site);
const entries = catalogEntries(artwork);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: displayTitle,
  url: canonical.href,
  image: artwork.data.images.map((img) => new URL(img.src, site).href),
  ...(description ? { description } : {}),
  creator: { '@type': 'Person', name: settings.artistName },
  ...(artwork.data.dimensions ? { size: artwork.data.dimensions } : {}),
  offers: entries.length
    ? entries.map((e) => ({
        '@type': 'Offer',
        name:
          e.variant.kind === 'print'
            ? `${displayTitle} — fine art print ${e.variant.size} (${e.variant.support === 'canvas' ? 'canvas' : 'paper'})`
            : displayTitle,
        price: e.price,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/InStock',
        url: canonical.href,
      }))
    : {
        '@type': 'Offer',
        price: artwork.data.price,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/SoldOut',
        url: canonical.href,
      },
};
---

<Base
  locale={locale}
  title={displayTitle}
  description={description}
  ogImage={cover.src}
  ogType="product"
  schema={schema}
>
  <a
    href={localizePath(locale, '/')}
    class="mb-8 inline-flex items-center gap-2 text-xs tracking-widest uppercase opacity-60 transition hover:opacity-100"
  >
    <span class="rtl:rotate-180">←</span>
    {t('artwork.backToWorks')}
  </a>

  {/* Titolo sopra il quadro */}
  <h1 class="font-serif text-3xl leading-tight sm:text-4xl">{displayTitle}</h1>
  {collectionLine && <p class="mt-2 text-sm tracking-wide opacity-70">{collectionLine}</p>}

  <div class="mt-8 grid gap-10 lg:grid-cols-5">
    <div class="lg:col-span-3">
      {/* Carosello: una foto alla volta, frecce e miniature cliccabili */}
      <div class="relative">
        <div id="artwork-gallery">
          {
            artwork.data.images.map((img, i) => (
              <a
                href={img.src}
                data-pswp-width={img.width}
                data-pswp-height={img.height}
                data-slide={i}
                target="_blank"
                rel="noreferrer"
                class:list={['block cursor-zoom-in bg-neutral-100', i > 0 && 'hidden']}
              >
                <Image
                  src={img}
                  alt={`${artwork.data.title}${i > 0 ? ` (${i + 1})` : ''}`}
                  width={1100}
                  class="w-full"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </a>
            ))
          }
        </div>
        {
          /* Zone invisibili ai bordi: toccando i lati della foto si scorre,
             il centro resta per lo zoom. Nessuna freccia disegnata sopra. */
          artwork.data.images.length > 1 && (
            <>
              <button
                type="button"
                data-slide-prev
                aria-label="←"
                class="absolute inset-y-0 start-0 z-10 w-1/6 cursor-pointer"
              />
              <button
                type="button"
                data-slide-next
                aria-label="→"
                class="absolute inset-y-0 end-0 z-10 w-1/6 cursor-pointer"
              />
            </>
          )
        }
      </div>
      {
        artwork.data.images.length > 1 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {artwork.data.images.map((img, i) => (
              <button
                type="button"
                data-thumb={i}
                class:list={[
                  'block w-16 cursor-pointer overflow-hidden border-2 bg-neutral-100 transition',
                  i === 0 ? 'border-ink' : 'border-transparent opacity-60 hover:opacity-100',
                ]}
              >
                <Image
                  src={img}
                  alt=""
                  width={160}
                  class="aspect-square w-full object-cover"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        )
      }
      <p class="mt-3 text-xs opacity-50">{t('artwork.zoomHint')}</p>
    </div>

    <div class="lg:col-span-2">
      {
        (artwork.data.dimensions ||
          (isPrint && artwork.data.showAvailability && artwork.data.editionSize)) && (
          <dl class="mt-8 space-y-3 border-y border-neutral-200 py-6 text-sm">
            {artwork.data.dimensions && (
              <div class="flex justify-between gap-4">
                <dt class="opacity-60">{t('artwork.dimensions')}</dt>
                <dd>{artwork.data.dimensions}</dd>
              </div>
            )}
            {isPrint && artwork.data.showAvailability && artwork.data.editionSize && (
              <div class="flex justify-between gap-4">
                <dt class="opacity-60">{t('artwork.editionOf', { n: artwork.data.editionSize })}</dt>
                <dd>
                  {available
                    ? t('artwork.remaining', { n: artwork.data.stock ?? 0 })
                    : t('artwork.soldOut')}
                </dd>
              </div>
            )}
          </dl>
        )
      }

      {
        printFormats.length > 0 && (
          <div class="mt-8 rounded-sm border border-olive/30 bg-olive/10 p-5 sm:p-6">
            <h2 class="text-xs font-semibold tracking-[0.25em] text-olive uppercase">
              {t('artwork.prints')}
            </h2>
            <p data-print-price class="mt-4 text-4xl font-semibold text-olive">
              {defaultFormat.priceLabels.paper}
            </p>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <label class="flex flex-col gap-2 text-sm">
                <span class="flex items-center justify-between gap-2">
                  <span class="opacity-60">{t('artwork.size')}</span>
                  {/* Selettore unità: le misure nel menu si mostrano in cm o pollici */}
                  <span class="flex overflow-hidden rounded-sm border border-olive/40 text-xs">
                    <button type="button" data-unit="cm" class="cursor-pointer px-2 py-0.5">cm</button>
                    <button type="button" data-unit="in" class="cursor-pointer border-s border-olive/40 px-2 py-0.5">in</button>
                  </span>
                </span>
                <select data-print-size class="border border-olive/40 bg-white px-3 py-2.5">
                  {
                    (['a', 'eu', 'in'] as const).map((g) => {
                      const inGroup = printData.formats.filter((f) => f.group === g);
                      if (inGroup.length === 0) return null;
                      const groupLabel = t(
                        g === 'a' ? 'artwork.groupA' : g === 'eu' ? 'artwork.groupEu' : 'artwork.groupIn'
                      );
                      return (
                        <optgroup label={groupLabel}>
                          {inGroup.map((f) => (
                            <option value={f.id} selected={f.id === defaultFormat.id}>
                              {f.label}
                            </option>
                          ))}
                        </optgroup>
                      );
                    })
                  }
                </select>
              </label>
              <label class="flex flex-col gap-2 text-sm">
                <span class="opacity-60">{t('artwork.support')}</span>
                <select data-print-support class="border border-olive/40 bg-white px-3 py-2.5">
                  <option value="paper">{t('artwork.supportPaper')}</option>
                  <option value="canvas">{t('artwork.supportCanvas')}</option>
                </select>
              </label>
              <label class="flex flex-col gap-2 text-sm">
                <span class="flex items-center gap-1.5 opacity-60">
                  {t('artwork.border')}
                  <button
                    type="button"
                    data-info-toggle="border-info"
                    aria-expanded="false"
                    class="flex size-4.5 cursor-pointer items-center justify-center rounded-full border border-current text-[0.65rem] leading-none opacity-80 hover:opacity-100"
                  >
                    i
                  </button>
                </span>
                <select data-print-border class="border border-olive/40 bg-white px-3 py-2.5">
                  {printData.borders.map((b) => (
                    <option value={b}>
                      {b === 0 ? t('artwork.borderNone') : t('artwork.borderCm', { n: b })}
                    </option>
                  ))}
                </select>
              </label>
              <label class="flex flex-col gap-2 text-sm">
                <span class="opacity-60">{t('artwork.quantity')}</span>
                <select data-print-qty class="border border-olive/40 bg-white px-3 py-2.5">
                  {Array.from({ length: 10 }, (_, i) => (
                    <option value={i + 1}>{i + 1}</option>
                  ))}
                </select>
              </label>
            </div>
            <p id="border-info" class="mt-3 hidden text-xs leading-relaxed opacity-70">
              {t('artwork.borderInfo')}
            </p>
            <p data-ratio-note class="mt-3 hidden text-xs leading-relaxed text-accent">
              {t('artwork.ratioNote')}
            </p>
            <button
              data-add-print
              data-label={t('artwork.addToCart')}
              data-added-label={t('artwork.addedToCart')}
              class="mt-5 w-full cursor-pointer bg-olive px-8 py-3 text-sm tracking-widest text-white uppercase transition hover:bg-[#5c662c]"
            >
              {t('artwork.addToCart')}
            </button>

            {/* L'anteprima del foglio stampato si apre in una finestra, su richiesta */}
            <button
              type="button"
              data-open-preview
              class="paper-btn-outline mt-3 w-full px-8 py-2.5 text-center text-xs tracking-widest uppercase"
            >
              👁 {t('artwork.previewTitle')}
            </button>

            {/* Informazioni: stampa e materiali, formati, cornici */}
            <div class="mt-5 divide-y divide-olive/20 border-t border-olive/20 text-sm">
              {printMaterials && (
                <details class="group py-2.5">
                  <summary class="flex cursor-pointer items-center justify-between gap-2 font-semibold">
                    {t('artwork.infoPrintProcess')}
                    <span class="transition group-open:rotate-45">+</span>
                  </summary>
                  <p class="mt-2 leading-relaxed whitespace-pre-line opacity-80">{printMaterials}</p>
                </details>
              )}
              <details class="group py-2.5">
                <summary class="flex cursor-pointer items-center justify-between gap-2 font-semibold">
                  {t('artwork.infoSizing')}
                  <span class="transition group-open:rotate-45">+</span>
                </summary>
                <p class="mt-2 leading-relaxed opacity-80">{t('artwork.sizingInfo')}</p>
                <p class="mt-2 leading-relaxed opacity-80">{t('artwork.borderInfo')}</p>
              </details>
              <details class="group py-2.5">
                <summary class="flex cursor-pointer items-center justify-between gap-2 font-semibold">
                  {t('artwork.infoFraming')}
                  <span class="transition group-open:rotate-45">+</span>
                </summary>
                <p class="mt-2 leading-relaxed opacity-80">{t('artwork.framingInfo')}</p>
              </details>
            </div>
          </div>
        )
      }

      {
        inquiryOnly ? (
          <div class="mt-6 flex flex-wrap items-center justify-between gap-x-4 gap-y-3 rounded-sm border border-neutral-300/80 bg-white/40 px-4 py-3.5">
            <p class="text-xs font-semibold tracking-[0.2em] text-accent uppercase">
              {t('artwork.originalOnRequest')}
            </p>
            <button
              type="button"
              data-open-inquiry
              data-inq-type="original"
              class="paper-btn px-5 py-2.5 text-xs tracking-[0.15em] text-white uppercase"
            >
              {t('artwork.requestOriginal')}
            </button>
          </div>
        ) : (
          <div class="mt-8">
            <p class="text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
              {t('artwork.original')}
            </p>
            <p class="mt-2 text-4xl font-semibold text-accent">
              {available ? formatPrice(artwork.data.price ?? 0, locale) : unavailableLabel}
            </p>

            {available ? (
              <div class="mt-5 flex flex-wrap items-center gap-4">
                {isPrint && max > 1 && (
                  <label class="flex items-center gap-2 text-sm">
                    <span class="opacity-60">{t('artwork.quantity')}</span>
                    <select data-qty-input class="border border-neutral-300 bg-white px-3 py-2.5">
                      {Array.from({ length: Math.min(max, 10) }, (_, i) => (
                        <option value={i + 1}>{i + 1}</option>
                      ))}
                    </select>
                  </label>
                )}
                <button
                  data-add-to-cart
                  data-slug={artwork.id}
                  data-max={max}
                  data-label={isPrint ? t('artwork.addToCart') : t('artwork.buyOriginal')}
                  data-added-label={t('artwork.addedToCart')}
                  class="paper-btn px-8 py-3 text-sm tracking-widest text-white uppercase"
                >
                  {isPrint ? t('artwork.addToCart') : t('artwork.buyOriginal')}
                </button>
              </div>
            ) : (
              <p class="mt-4 inline-block bg-neutral-200 px-4 py-2 text-xs tracking-widest uppercase">
                {unavailableLabel}
              </p>
            )}
          </div>
        )
      }

      {
        description && (
          <div class="mt-10">
            <h2 class="text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
              {t('artwork.description')}
            </h2>
            <p class="mt-3 leading-relaxed whitespace-pre-line opacity-80">{description}</p>
          </div>
        )
      }
    </div>
  </div>

  {
    alsoLike.length > 0 && (
      <section class="mt-16 border-t border-neutral-200 pt-10">
        <h2 class="font-serif text-2xl sm:text-3xl">{t('artwork.alsoLike')}</h2>
        <div
          data-also-like
          class="mt-6 flex snap-x gap-5 overflow-x-auto pb-3"
        >
          {alsoLike.map((a) => (
            <a
              href={localizePath(locale, `/opere/${a.id}`)}
              class="group w-40 shrink-0 snap-start sm:w-48"
            >
              <div class="overflow-hidden bg-neutral-100">
                <Image
                  src={a.data.images[0]}
                  alt={pickLocalized(a.data.titles, locale) || a.data.title}
                  width={400}
                  class="aspect-4/5 w-full object-cover transition duration-500 group-hover:scale-[1.04]"
                  loading="lazy"
                />
              </div>
              <p class="mt-2 font-serif text-sm leading-snug">
                {pickLocalized(a.data.titles, locale) || a.data.title}
              </p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  {/* Finestra con l'anteprima del foglio stampato (proporzioni e bordi reali) */}
  {
    printFormats.length > 0 && (
      <dialog
        data-preview-modal
        class="paper-panel w-[min(36rem,92vw)] p-0 backdrop:bg-ink/40 backdrop:backdrop-blur-sm"
      >
        <div class="p-6 sm:p-8">
          <div class="flex items-start justify-between gap-4">
            <h2 class="font-serif text-2xl leading-tight">{t('artwork.previewTitle')}</h2>
            <button
              type="button"
              data-preview-close
              aria-label="×"
              class="-mt-1 shrink-0 cursor-pointer text-2xl leading-none opacity-50 transition hover:opacity-100"
            >
              ×
            </button>
          </div>
          <div class="mt-5 flex justify-center bg-neutral-200/60 p-4">
            <div
              data-print-preview
              class="flex max-h-[60vh] items-center justify-center bg-white shadow-md"
              style={`aspect-ratio: ${defaultFormat.width} / ${defaultFormat.height}; max-width: 100%;`}
            >
              <img
                src={cover.src}
                alt=""
                class="max-h-full max-w-full"
                style="object-fit: contain; width: 100%; height: 100%;"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </dialog>
    )
  }

  {/* Finestra (modale) per richiesta originale / informazioni */}
  <dialog
    data-inquiry-modal
    class="paper-panel w-[min(30rem,92vw)] p-0 backdrop:bg-ink/40 backdrop:backdrop-blur-sm"
  >
    <form
      data-inquiry-form
      data-artwork={displayTitle}
      data-email={settings.contactEmail ?? ''}
      data-title-original={t('inquiry.title')}
      data-title-info={t('artwork.askInfo')}
      data-intro={t('inquiry.intro')}
      data-msg-original={inquiryOriginalMessage}
      data-msg-info={inquiryInfoMessage}
      data-subject-original="Richiesta originale"
      data-subject-info="Richiesta informazioni"
      data-label-send={t('inquiry.send')}
      data-label-sending={t('inquiry.sending')}
      data-label-sent={t('inquiry.sent')}
      data-label-error={t('inquiry.error')}
      data-label-not-configured={t('inquiry.notConfigured')}
      class="flex flex-col gap-3 p-6 sm:p-8"
    >
      <div class="flex items-start justify-between gap-4">
        <h2 data-inq-title class="font-serif text-2xl leading-tight"></h2>
        <button
          type="button"
          data-inq-close
          aria-label="×"
          class="-mt-1 shrink-0 text-2xl leading-none opacity-50 transition hover:opacity-100"
        >
          ×
        </button>
      </div>
      <p data-inq-intro class="text-sm opacity-70"></p>
      <input
        data-inq-name
        name="name"
        required
        autocomplete="name"
        placeholder={t('inquiry.name')}
        class="border border-neutral-300 bg-white/70 px-3 py-2.5 text-sm"
      />
      <input
        data-inq-email
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder={t('inquiry.email')}
        class="border border-neutral-300 bg-white/70 px-3 py-2.5 text-sm"
      />
      <textarea
        data-inq-message
        name="message"
        required
        rows="4"
        class="border border-neutral-300 bg-white/70 px-3 py-2.5 text-sm"
      ></textarea>
      <button
        type="submit"
        data-inq-send
        class="paper-btn px-8 py-3 text-sm tracking-widest text-white uppercase disabled:cursor-wait disabled:opacity-50"
      >
        {t('inquiry.send')}
      </button>
      <p data-inq-status class="hidden text-sm"></p>
      <a
        data-inq-fallback
        href="#"
        class="paper-btn-outline hidden px-8 py-3 text-center text-sm tracking-widest uppercase"
      >
        {t('inquiry.fallback')}
      </a>
    </form>
  </dialog>

  <script type="application/json" id="print-data" set:html={JSON.stringify(printData)} />
</Base>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';
  import { addToCart } from '../../scripts/cart';
  import { track } from '../../scripts/analytics';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#artwork-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    wheelToZoom: true,
    initialZoomLevel: 'fit',
    secondaryZoomLevel: 2.5,
    maxZoomLevel: 8,
  });
  lightbox.on('beforeOpen', () => track('zoom'));
  lightbox.init();

  // Carosello immagini: frecce + miniature
  const slides = Array.from(document.querySelectorAll<HTMLElement>('#artwork-gallery [data-slide]'));
  const thumbs = Array.from(document.querySelectorAll<HTMLElement>('[data-thumb]'));
  if (slides.length > 1) {
    let current = 0;
    const show = (i: number) => {
      current = (i + slides.length) % slides.length;
      slides.forEach((s, j) => s.classList.toggle('hidden', j !== current));
      thumbs.forEach((th, j) => {
        th.classList.toggle('border-ink', j === current);
        th.classList.toggle('border-transparent', j !== current);
        th.classList.toggle('opacity-60', j !== current);
      });
    };
    document.querySelector('[data-slide-prev]')?.addEventListener('click', () => show(current - 1));
    document.querySelector('[data-slide-next]')?.addEventListener('click', () => show(current + 1));
    thumbs.forEach((th) => th.addEventListener('click', () => show(parseInt(th.dataset.thumb!, 10))));
  }

  document.querySelectorAll<HTMLButtonElement>('[data-add-to-cart]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const qtyInput = document.querySelector<HTMLSelectElement>('[data-qty-input]');
      const qty = qtyInput ? parseInt(qtyInput.value, 10) : 1;
      addToCart(btn.dataset.slug!, qty, parseInt(btn.dataset.max!, 10));
      btn.textContent = btn.dataset.addedLabel!;
      setTimeout(() => {
        btn.textContent = btn.dataset.label!;
      }, 1800);
    });
  });

  // Stampe: formato + supporto + bordo, con prezzo, avviso proporzioni e anteprima
  type PrintFormatData = {
    id: string;
    label: string;
    name: string;
    group: string;
    width: number;
    height: number;
    prices: Record<string, number>;
    priceLabels: Record<string, string>;
    ratioMismatch: boolean;
  };
  const printDataEl = document.getElementById('print-data');
  const sizeSelect = document.querySelector<HTMLSelectElement>('[data-print-size]');
  const supportSelect = document.querySelector<HTMLSelectElement>('[data-print-support]');
  const borderSelect = document.querySelector<HTMLSelectElement>('[data-print-border]');
  const qtySelect = document.querySelector<HTMLSelectElement>('[data-print-qty]');
  const printBtn = document.querySelector<HTMLButtonElement>('[data-add-print]');
  if (printDataEl && sizeSelect && supportSelect && borderSelect && qtySelect && printBtn) {
    const data = JSON.parse(printDataEl.textContent!) as {
      slug: string;
      separator: string;
      imageRatio: number;
      defaultUnit: 'cm' | 'in';
      lang: string;
      formats: PrintFormatData[];
    };
    const byId = new Map(data.formats.map((f) => [f.id, f]));

    // Misure in cm o pollici, a scelta del visitatore
    let unit: 'cm' | 'in' = data.defaultUnit;
    const unitBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-unit]'));
    const fmtNum = (n: number) => {
      const rounded = Math.round(n * 10) / 10;
      return rounded.toLocaleString(data.lang);
    };
    const dimsLabel = (f: PrintFormatData) =>
      unit === 'in'
        ? `${fmtNum(f.width / 2.54)} × ${fmtNum(f.height / 2.54)} in`
        : `${fmtNum(f.width)} × ${fmtNum(f.height)} cm`;
    const applyUnit = () => {
      unitBtns.forEach((b) => {
        const active = b.dataset.unit === unit;
        b.classList.toggle('bg-olive', active);
        b.classList.toggle('text-white', active);
      });
      sizeSelect.querySelectorAll('option').forEach((opt) => {
        const f = byId.get(opt.value);
        if (f) opt.textContent = f.name ? `${f.name} · ${dimsLabel(f)}` : dimsLabel(f);
      });
    };
    unitBtns.forEach((b) =>
      b.addEventListener('click', () => {
        unit = b.dataset.unit === 'in' ? 'in' : 'cm';
        applyUnit();
      })
    );
    applyUnit();
    const priceEl = document.querySelector<HTMLElement>('[data-print-price]');
    const ratioNote = document.querySelector<HTMLElement>('[data-ratio-note]');
    const preview = document.querySelector<HTMLElement>('[data-print-preview]');
    const previewImg = preview?.querySelector('img');

    const refresh = () => {
      const fmt = byId.get(sizeSelect.value) ?? data.formats[0];
      const support = supportSelect.value === 'canvas' ? 'canvas' : 'paper';
      if (priceEl) priceEl.textContent = fmt.priceLabels[support];
      ratioNote?.classList.toggle('hidden', !fmt.ratioMismatch);
      if (preview) {
        // Il foglio segue l'orientamento del dipinto (come farebbe la stamperia)
        const landscape = data.imageRatio > 1;
        const w = landscape ? Math.max(fmt.width, fmt.height) : Math.min(fmt.width, fmt.height);
        const h = landscape ? Math.min(fmt.width, fmt.height) : Math.max(fmt.width, fmt.height);
        preview.style.aspectRatio = `${w} / ${h}`;
        // Bordo bianco extra in scala: b cm rispetto alla larghezza del foglio
        const b = parseInt(borderSelect.value, 10) || 0;
        preview.style.padding = `${(b / w) * 100}%`;
        if (previewImg) {
          previewImg.style.width = '100%';
          previewImg.style.height = '100%';
        }
      }
    };
    sizeSelect.addEventListener('change', refresh);
    supportSelect.addEventListener('change', refresh);
    borderSelect.addEventListener('change', refresh);
    refresh();

    // Finestra dell'anteprima di stampa
    const previewModal = document.querySelector<HTMLDialogElement>('[data-preview-modal]');
    document.querySelector<HTMLButtonElement>('[data-open-preview]')?.addEventListener('click', () => {
      refresh();
      previewModal?.showModal();
    });
    previewModal?.querySelector('[data-preview-close]')?.addEventListener('click', () => previewModal.close());
    previewModal?.addEventListener('click', (e) => {
      if (e.target === previewModal) previewModal.close();
    });

    printBtn.addEventListener('click', () => {
      const support = supportSelect.value === 'canvas' ? 'canvas' : 'paper';
      const id = [data.slug, sizeSelect.value, support].join(data.separator);
      const border = parseInt(borderSelect.value, 10) || 0;
      addToCart(id, parseInt(qtySelect.value, 10) || 1, 10, border);
      printBtn.textContent = printBtn.dataset.addedLabel!;
      setTimeout(() => {
        printBtn.textContent = printBtn.dataset.label!;
      }, 1800);
    });
  }

  // Popover "i" del bordo bianco
  document.querySelectorAll<HTMLButtonElement>('[data-info-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.infoToggle!);
      const open = target?.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
    });
  });

  // "Potrebbero piacerti anche": ordine casuale a ogni visita
  const alsoLikeRow = document.querySelector<HTMLElement>('[data-also-like]');
  if (alsoLikeRow) {
    const cards = Array.from(alsoLikeRow.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }
    cards.forEach((c) => alsoLikeRow.appendChild(c));
  }

  // Finestra "richiesta originale / informazioni": apertura, precompilazione, invio.
  const modal = document.querySelector<HTMLDialogElement>('[data-inquiry-modal]');
  const inquiryForm = modal?.querySelector<HTMLFormElement>('[data-inquiry-form]');
  if (modal && inquiryForm) {
    const titleEl = inquiryForm.querySelector<HTMLElement>('[data-inq-title]')!;
    const introEl = inquiryForm.querySelector<HTMLElement>('[data-inq-intro]')!;
    const nameEl = inquiryForm.querySelector<HTMLInputElement>('[data-inq-name]')!;
    const emailEl = inquiryForm.querySelector<HTMLInputElement>('[data-inq-email]')!;
    const messageEl = inquiryForm.querySelector<HTMLTextAreaElement>('[data-inq-message]')!;
    const sendBtn = inquiryForm.querySelector<HTMLButtonElement>('[data-inq-send]')!;
    const status = inquiryForm.querySelector<HTMLElement>('[data-inq-status]')!;
    const fallback = inquiryForm.querySelector<HTMLAnchorElement>('[data-inq-fallback]');
    let type: 'original' | 'info' = 'original';

    function resetView() {
      inquiryForm!
        .querySelectorAll('[data-inq-name], [data-inq-email], [data-inq-message], [data-inq-send]')
        .forEach((el) => (el as HTMLElement).classList.remove('hidden'));
      status.classList.add('hidden');
      fallback?.classList.add('hidden');
      sendBtn.disabled = false;
      sendBtn.textContent = inquiryForm!.dataset.labelSend!;
    }

    document.querySelectorAll<HTMLButtonElement>('[data-open-inquiry]').forEach((btn) => {
      btn.addEventListener('click', () => {
        type = btn.dataset.inqType === 'info' ? 'info' : 'original';
        titleEl.textContent =
          type === 'info' ? inquiryForm.dataset.titleInfo! : inquiryForm.dataset.titleOriginal!;
        introEl.textContent = inquiryForm.dataset.intro!;
        messageEl.value =
          type === 'info' ? inquiryForm.dataset.msgInfo! : inquiryForm.dataset.msgOriginal!;
        resetView();
        track('inquiry_open', { type });
        modal.showModal();
      });
    });

    inquiryForm.querySelector('[data-inq-close]')!.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    inquiryForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = nameEl.value.trim();
      const email = emailEl.value.trim();
      const message = messageEl.value.trim();
      if (!name || !email || !message) return;
      sendBtn.disabled = true;
      sendBtn.textContent = inquiryForm.dataset.labelSending!;
      status.classList.add('hidden');
      fallback?.classList.add('hidden');
      try {
        const res = await fetch('/api/inquiry', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type,
            name,
            email,
            message,
            artwork: inquiryForm.dataset.artwork,
            url: location.href,
          }),
        });
        if (res.ok) {
          inquiryForm
            .querySelectorAll('[data-inq-name], [data-inq-email], [data-inq-message], [data-inq-send]')
            .forEach((el) => (el as HTMLElement).classList.add('hidden'));
          status.textContent = inquiryForm.dataset.labelSent!;
          status.className = 'text-sm text-olive';
          status.classList.remove('hidden');
          track('inquiry_sent', { type });
        } else {
          throw new Error(String(res.status));
        }
      } catch (err) {
        // 503 = modulo non ancora configurato: messaggio più gentile,
        // il mailto qui sotto recapita comunque il messaggio all'artista
        const notConfigured = err instanceof Error && err.message === '503';
        status.textContent = notConfigured
          ? inquiryForm.dataset.labelNotConfigured!
          : inquiryForm.dataset.labelError!;
        status.className = notConfigured ? 'text-sm opacity-80' : 'text-sm text-accent';
        status.classList.remove('hidden');
        // Fallback: apre il client email verso l'artista, oggetto per tipo + email cliente
        const artworkTitle = inquiryForm.dataset.artwork ?? '';
        const kind =
          type === 'info' ? inquiryForm.dataset.subjectInfo! : inquiryForm.dataset.subjectOriginal!;
        const subject = [kind, artworkTitle, email].filter(Boolean).join(' — ');
        const to = inquiryForm.dataset.email;
        if (fallback && to) {
          const body = `${message}\n\n${name} (${email})`;
          fallback.href = `mailto:${to}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
          fallback.classList.remove('hidden');
        }
        sendBtn.disabled = false;
        sendBtn.textContent = inquiryForm.dataset.labelSend!;
      }
    });
  }
</script>
