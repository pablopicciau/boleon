---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import settings from '../../content/settings.json';
import {
  availablePrintSizes,
  catalogEntries,
  isBaseAvailable,
  maxQty,
  PRINT_ID_SEPARATOR,
  type Artwork,
} from '../../lib/artworks';
import {
  formatPrice,
  localizePath,
  pickLocalized,
  useTranslations,
  type Locale,
} from '../../i18n';

interface Props {
  locale: Locale;
  artwork: Artwork;
}

const { locale, artwork } = Astro.props;
const t = useTranslations(locale);
const available = isBaseAvailable(artwork);
const max = maxQty(artwork);
const isPrint = artwork.data.kind === 'print';
const description = pickLocalized(artwork.data.descriptions, locale);
const unavailableLabel = t(isPrint ? 'artwork.soldOut' : 'artwork.sold');
const printSizes = availablePrintSizes(artwork);
const printMaterials = pickLocalized(
  (settings as { printMaterials?: Record<string, string | null> }).printMaterials,
  locale
);
const askInfoHref = settings.contactEmail
  ? `mailto:${settings.contactEmail}?subject=${encodeURIComponent(`${artwork.data.title} — ${t('artwork.askInfo')}`)}`
  : null;

const site = Astro.site ?? new URL('https://boleon.it');
const canonical = new URL(Astro.url.pathname, site);
const cover = artwork.data.images[0];
const entries = catalogEntries(artwork);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: artwork.data.title,
  url: canonical.href,
  image: artwork.data.images.map((img) => new URL(img.src, site).href),
  ...(description ? { description } : {}),
  creator: { '@type': 'Person', name: settings.artistName },
  dateCreated: String(artwork.data.year),
  ...(artwork.data.technique ? { artMedium: artwork.data.technique } : {}),
  ...(artwork.data.dimensions ? { size: artwork.data.dimensions } : {}),
  artEdition: isPrint ? (artwork.data.editionSize ?? undefined) : 1,
  offers: entries.length
    ? entries.map((e) => ({
        '@type': 'Offer',
        name:
          e.variant.kind === 'print'
            ? `${artwork.data.title} — fine art print ${e.variant.size}`
            : artwork.data.title,
        price: e.price,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/InStock',
        url: canonical.href,
      }))
    : {
        '@type': 'Offer',
        price: artwork.data.price,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/SoldOut',
        url: canonical.href,
      },
};
---

<Base
  locale={locale}
  title={artwork.data.title}
  description={description}
  ogImage={cover.src}
  ogType="product"
  schema={schema}
>
  <a
    href={localizePath(locale, '/')}
    class="mb-8 inline-flex items-center gap-2 text-xs tracking-widest uppercase opacity-60 transition hover:opacity-100"
  >
    <span class="rtl:rotate-180">←</span>
    {t('artwork.backToWorks')}
  </a>

  <div class="grid gap-10 lg:grid-cols-5">
    <div class="lg:col-span-3">
      <div id="artwork-gallery" class="flex flex-col gap-4">
        {
          artwork.data.images.map((img, i) => (
            <a
              href={img.src}
              data-pswp-width={img.width}
              data-pswp-height={img.height}
              target="_blank"
              rel="noreferrer"
              class="block cursor-zoom-in bg-neutral-100"
            >
              <Image
                src={img}
                alt={`${artwork.data.title}${i > 0 ? ` (${i + 1})` : ''}`}
                width={1100}
                class="w-full"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </a>
          ))
        }
      </div>
      <p class="mt-3 text-xs opacity-50">{t('artwork.zoomHint')}</p>
    </div>

    <div class="lg:col-span-2">
      <h1 class="font-serif text-3xl leading-tight sm:text-4xl">{artwork.data.title}</h1>
      <p class="mt-2 text-sm tracking-widest uppercase opacity-60">
        {isPrint ? t('artwork.print') : t('artwork.original')}
      </p>

      <dl class="mt-8 space-y-3 border-y border-neutral-200 py-6 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="opacity-60">{t('artwork.year')}</dt>
          <dd>{artwork.data.year}</dd>
        </div>
        {
          artwork.data.technique && (
            <div class="flex justify-between gap-4">
              <dt class="opacity-60">{t('artwork.technique')}</dt>
              <dd class="text-end">{artwork.data.technique}</dd>
            </div>
          )
        }
        {
          artwork.data.dimensions && (
            <div class="flex justify-between gap-4">
              <dt class="opacity-60">{t('artwork.dimensions')}</dt>
              <dd>{artwork.data.dimensions}</dd>
            </div>
          )
        }
        {
          isPrint && artwork.data.editionSize && (
            <div class="flex justify-between gap-4">
              <dt class="opacity-60">{t('artwork.editionOf', { n: artwork.data.editionSize })}</dt>
              <dd>{available ? t('artwork.remaining', { n: artwork.data.stock ?? 0 }) : t('artwork.soldOut')}</dd>
            </div>
          )
        }
      </dl>

      <div class="mt-8">
        <p class="text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
          {t('artwork.original')}
        </p>
        <p class="mt-2 font-serif text-4xl text-accent">
          {available ? formatPrice(artwork.data.price, locale) : unavailableLabel}
        </p>

        {
          available ? (
            <div class="mt-5 flex flex-wrap items-center gap-4">
              {isPrint && max > 1 && (
                <label class="flex items-center gap-2 text-sm">
                  <span class="opacity-60">{t('artwork.quantity')}</span>
                  <select
                    data-qty-input
                    class="border border-neutral-300 bg-white px-3 py-2.5"
                  >
                    {Array.from({ length: Math.min(max, 10) }, (_, i) => (
                      <option value={i + 1}>{i + 1}</option>
                    ))}
                  </select>
                </label>
              )}
              <button
                data-add-to-cart
                data-slug={artwork.id}
                data-max={max}
                data-label={isPrint ? t('artwork.addToCart') : t('artwork.buyOriginal')}
                data-added-label={t('artwork.addedToCart')}
                class="cursor-pointer bg-accent px-8 py-3 text-sm tracking-widest text-white uppercase transition hover:bg-[#6f1f33]"
              >
                {isPrint ? t('artwork.addToCart') : t('artwork.buyOriginal')}
              </button>
            </div>
          ) : (
            <p class="mt-4 inline-block bg-neutral-200 px-4 py-2 text-xs tracking-widest uppercase">
              {unavailableLabel}
            </p>
          )
        }
      </div>

      {
        printSizes.length > 0 && (
          <div class="mt-12 rounded-sm border border-olive/30 bg-olive/10 p-5 sm:p-6">
            <h2 class="text-xs font-semibold tracking-[0.25em] text-olive uppercase">
              {t('artwork.prints')}
            </h2>
            <p data-print-price class="mt-2 font-serif text-4xl text-olive">
              {formatPrice(printSizes[0].price, locale)}
            </p>
            <div class="mt-4 flex flex-wrap items-end gap-4">
              <label class="flex flex-col gap-2 text-sm">
                <span class="opacity-60">{t('artwork.size')}</span>
                <select data-print-size class="border border-olive/40 bg-white px-3 py-2.5">
                  {printSizes.map((p) => (
                    <option
                      value={p.size}
                      data-price={p.price}
                      data-price-label={formatPrice(p.price, locale)}
                      data-max={Math.min(p.stock, 10)}
                    >
                      {p.size} — {formatPrice(p.price, locale)}
                    </option>
                  ))}
                </select>
              </label>
              <label class="flex flex-col gap-2 text-sm">
                <span class="opacity-60">{t('artwork.quantity')}</span>
                <select data-print-qty class="border border-olive/40 bg-white px-3 py-2.5"
                ></select>
              </label>
              <button
                data-add-print
                data-slug-base={artwork.id}
                data-separator={PRINT_ID_SEPARATOR}
                data-label={t('artwork.addToCart')}
                data-added-label={t('artwork.addedToCart')}
                class="cursor-pointer bg-olive px-8 py-3 text-sm tracking-widest text-white uppercase transition hover:bg-[#5c662c]"
              >
                {t('artwork.addToCart')}
              </button>
            </div>
            {
              printMaterials && (
                <p class="mt-4 max-w-prose text-xs leading-relaxed opacity-70">{printMaterials}</p>
              )
            }
          </div>
        )
      }

      {
        askInfoHref && (
          <a
            href={askInfoHref}
            class="mt-8 inline-flex items-center gap-2 text-xs tracking-widest uppercase opacity-60 underline-offset-4 transition hover:opacity-100 hover:underline"
          >
            ✉ {t('artwork.askInfo')}
          </a>
        )
      }

      {
        description && (
          <div class="mt-10">
            <h2 class="text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
              {t('artwork.description')}
            </h2>
            <p class="mt-3 leading-relaxed whitespace-pre-line opacity-80">{description}</p>
          </div>
        )
      }
    </div>
  </div>
</Base>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';
  import { addToCart } from '../../scripts/cart';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#artwork-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    wheelToZoom: true,
    initialZoomLevel: 'fit',
    secondaryZoomLevel: 2.5,
    maxZoomLevel: 8,
  });
  lightbox.init();

  document.querySelectorAll<HTMLButtonElement>('[data-add-to-cart]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const qtyInput = document.querySelector<HTMLSelectElement>('[data-qty-input]');
      const qty = qtyInput ? parseInt(qtyInput.value, 10) : 1;
      addToCart(btn.dataset.slug!, qty, parseInt(btn.dataset.max!, 10));
      btn.textContent = btn.dataset.addedLabel!;
      setTimeout(() => {
        btn.textContent = btn.dataset.label!;
      }, 1800);
    });
  });

  // Stampe in vari formati: il selettore aggiorna le quantità disponibili
  const sizeSelect = document.querySelector<HTMLSelectElement>('[data-print-size]');
  const qtySelect = document.querySelector<HTMLSelectElement>('[data-print-qty]');
  const printBtn = document.querySelector<HTMLButtonElement>('[data-add-print]');
  if (sizeSelect && qtySelect && printBtn) {
    const priceEl = document.querySelector<HTMLElement>('[data-print-price]');
    const currentMax = () =>
      parseInt(sizeSelect.selectedOptions[0]?.dataset.max ?? '1', 10) || 1;
    const rebuildQty = () => {
      const max = currentMax();
      qtySelect.innerHTML = Array.from(
        { length: max },
        (_, i) => `<option value="${i + 1}">${i + 1}</option>`
      ).join('');
      // Il prezzo grande segue il formato selezionato
      const label = sizeSelect.selectedOptions[0]?.dataset.priceLabel;
      if (priceEl && label) priceEl.textContent = label;
    };
    sizeSelect.addEventListener('change', rebuildQty);
    rebuildQty();

    printBtn.addEventListener('click', () => {
      const id = `${printBtn.dataset.slugBase}${printBtn.dataset.separator}${sizeSelect.value}`;
      addToCart(id, parseInt(qtySelect.value, 10) || 1, currentMax());
      printBtn.textContent = printBtn.dataset.addedLabel!;
      setTimeout(() => {
        printBtn.textContent = printBtn.dataset.label!;
      }, 1800);
    });
  }
</script>
