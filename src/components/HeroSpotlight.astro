---
import { getImage } from 'astro:assets';
import settings from '../content/settings.json';
import { pickLocalized, useTranslations, type Locale } from '../i18n';

/**
 * Hero a schermo intero con "spotlight" che segue il cursore e rivela
 * i colori dell'opera (base desaturata via CSS, quindi funziona con
 * qualunque immagine). Più immagini: una a caso all'apertura, poi
 * rotazione casuale ogni 10 secondi con dissolvenza.
 */
interface Props {
  locale: Locale;
  images: ImageMetadata[];
}

const { locale, images } = Astro.props;
const t = useTranslations(locale);
const tagline = pickLocalized(settings.taglines, locale);
const bio = pickLocalized(settings.bios, locale);

const optimized = await Promise.all(images.map((img) => getImage({ src: img, width: 1600 })));
const urls = optimized.map((o) => o.src);
const first = urls[0];

// Maschera iniziale al centro, prima che il puntatore si muova.
const initialMask =
  'radial-gradient(circle 260px at 50% 45%, rgb(0 0 0) 0%, rgb(0 0 0) 40%, rgb(0 0 0 / 0.75) 60%, rgb(0 0 0 / 0.4) 75%, rgb(0 0 0 / 0.12) 88%, transparent 100%)';
---

<section
  id="spotlight-hero"
  class="relative left-1/2 w-screen -translate-x-1/2 -mt-10 overflow-hidden bg-paper"
  style="height: calc(100dvh - 73px); min-height: 480px;"
>
  <div
    class="hero-zoom absolute inset-0 z-10"
    style="filter: grayscale(0.92) brightness(1.06);"
    data-hero-layer="base"
  >
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-100 transition-opacity duration-1000"
      style={`background-image: url('${first}')`}
      data-buffer="a"
    >
    </div>
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"
      data-buffer="b"
    >
    </div>
  </div>
  <div
    class="absolute inset-0 z-20 bg-gradient-to-b from-paper/85 via-transparent to-paper/70"
    aria-hidden="true"
  >
  </div>
  <div
    data-hero-reveal
    class="pointer-events-none absolute inset-0 z-30"
    style={`mask-image: ${initialMask}; -webkit-mask-image: ${initialMask}; mask-size: 100% 100%; -webkit-mask-size: 100% 100%;`}
    data-hero-layer="reveal"
  >
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-100 transition-opacity duration-1000"
      style={`background-image: url('${first}')`}
      data-buffer="a"
    >
    </div>
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"
      data-buffer="b"
    >
    </div>
  </div>

  <div class="pointer-events-none absolute top-[16%] right-0 left-0 z-50 flex flex-col items-center px-5 text-center">
    <h1 class="leading-[0.95] text-ink">
      <span
        class="hero-anim hero-reveal font-hand block text-5xl sm:text-7xl"
        style="letter-spacing: 0.02em; animation-delay: 0.25s;"
      >
        {settings.artistName}
      </span>
      {
        tagline && (
          <span
            class="hero-anim hero-reveal mt-4 block text-base font-light tracking-wide text-ink/70 sm:text-xl"
            style="animation-delay: 0.42s;"
          >
            {tagline}
          </span>
        )
      }
    </h1>
  </div>

  {
    bio && (
      <div class="hero-anim hero-fade absolute bottom-14 start-10 z-50 hidden max-w-[280px] sm:block" style="animation-delay: 0.7s;">
        <p class="text-sm leading-relaxed text-ink/70">{bio}</p>
      </div>
    )
  }

  <div
    class="hero-anim hero-fade absolute start-5 end-5 bottom-10 z-50 flex max-w-full flex-col items-start gap-4 sm:start-auto sm:end-10 sm:bottom-24 sm:max-w-[280px]"
    style="animation-delay: 0.85s;"
  >
    <p class="text-xs leading-relaxed text-ink/70 sm:text-sm">{t('hero.invite')}</p>
    <a
      href="#opere"
      class="rounded-full bg-accent px-7 py-3 text-sm font-medium tracking-wide text-white uppercase transition-all hover:scale-[1.03] hover:bg-[#6f1f33] hover:shadow-lg hover:shadow-accent/30 active:scale-95"
    >
      {t('hero.cta')}
    </a>
  </div>

  <script type="application/json" id="hero-images" set:html={JSON.stringify(urls)} />
</section>

<script>
  const section = document.getElementById('spotlight-hero');
  const reveal = section?.querySelector<HTMLElement>('[data-hero-reveal]');

  if (section && reveal) {
    const R = 260;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Spotlight che segue il puntatore ----
    const rect = () => section.getBoundingClientRect();
    const raw = { x: rect().width / 2, y: rect().height * 0.45 };
    const pos = { ...raw };

    const apply = () => {
      const g = `radial-gradient(circle ${R}px at ${pos.x}px ${pos.y}px, rgb(0 0 0) 0%, rgb(0 0 0) 40%, rgb(0 0 0 / 0.75) 60%, rgb(0 0 0 / 0.4) 75%, rgb(0 0 0 / 0.12) 88%, transparent 100%)`;
      reveal.style.maskImage = g;
      reveal.style.webkitMaskImage = g;
    };

    section.addEventListener('pointermove', (e) => {
      const r = rect();
      raw.x = e.clientX - r.left;
      raw.y = e.clientY - r.top;
    });

    if (reduced) {
      apply();
    } else {
      const tick = () => {
        pos.x += (raw.x - pos.x) * 0.1;
        pos.y += (raw.y - pos.y) * 0.1;
        apply();
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    // ---- Rotazione casuale degli sfondi ----
    const urls: string[] = JSON.parse(document.getElementById('hero-images')!.textContent!);
    if (urls.length > 1) {
      const layers = section.querySelectorAll<HTMLElement>('[data-hero-layer]');
      let front: 'a' | 'b' = 'a';
      let current = 0;

      const show = (idx: number) => {
        const back = front === 'a' ? 'b' : 'a';
        layers.forEach((layer) => {
          const backEl = layer.querySelector<HTMLElement>(`[data-buffer="${back}"]`)!;
          const frontEl = layer.querySelector<HTMLElement>(`[data-buffer="${front}"]`)!;
          backEl.style.backgroundImage = `url('${urls[idx]}')`;
          backEl.style.opacity = '1';
          frontEl.style.opacity = '0';
        });
        front = back;
        current = idx;
      };

      const randomOther = () => {
        let idx = Math.floor(Math.random() * urls.length);
        if (idx === current) idx = (idx + 1) % urls.length;
        return idx;
      };

      // Apertura: immagine scelta a caso
      const start = Math.floor(Math.random() * urls.length);
      if (start !== 0) show(start);

      // Poi una diversa ogni 10 secondi (salvo riduzione animazioni)
      if (!reduced) {
        setInterval(() => {
          if (!document.hidden) show(randomOther());
        }, 10000);
      }
    }
  }
</script>
