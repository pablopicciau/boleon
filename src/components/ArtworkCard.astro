---
import { Image } from 'astro:assets';
import {
  getOptions,
  isAvailable,
  minAvailablePrice,
  offerKind,
  type Artwork,
} from '../lib/artworks';
import { formatPrice, localizePath, useTranslations, type Locale } from '../i18n';

interface Props {
  artwork: Artwork;
  locale: Locale;
}

const { artwork, locale } = Astro.props;
const t = useTranslations(locale);
const available = isAvailable(artwork);
const kind = offerKind(artwork);
const cover = artwork.data.images[0];
const href = localizePath(locale, `/opere/${artwork.id}`);

const soldLabel = t(kind === 'print' ? 'artwork.soldOut' : 'artwork.sold');
const kindLabel =
  kind === 'both'
    ? t('artwork.originalAndPrints')
    : kind === 'print'
      ? t('artwork.print')
      : t('artwork.original');

const minPrice = minAvailablePrice(artwork);
const availableCount = getOptions(artwork).filter((o) => o.available).length;
const priceLabel =
  minPrice == null
    ? soldLabel
    : availableCount > 1
      ? t('artwork.from', { price: formatPrice(minPrice, locale) })
      : formatPrice(minPrice, locale);
---

<a href={href} class="group block">
  <div class="relative overflow-hidden bg-neutral-100">
    <Image
      src={cover}
      alt={artwork.data.title}
      width={800}
      class="aspect-4/5 w-full object-cover transition duration-700 ease-out group-hover:scale-[1.025]"
    />
    {
      !available && (
        <span class="absolute top-3 start-3 bg-ink/90 px-2.5 py-1 text-[0.65rem] tracking-[0.2em] text-white uppercase">
          {soldLabel}
        </span>
      )
    }
  </div>
  <div class="mt-4 flex items-baseline justify-between gap-3">
    <h3 class="font-serif text-xl leading-snug font-medium">
      {artwork.data.title}<span class="ms-2 text-sm font-normal opacity-50">{artwork.data.year}</span>
    </h3>
    <p class="shrink-0 text-sm opacity-80">{priceLabel}</p>
  </div>
  <p class="mt-0.5 text-xs tracking-wide opacity-50">{kindLabel}</p>
</a>
