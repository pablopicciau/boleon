---
import { getCollection } from 'astro:content';
import ArtworkDetail from '../../../components/pages/ArtworkDetail.astro';
import { secondaryLocales, type Locale } from '../../../i18n';

export async function getStaticPaths() {
  const artworks = await getCollection('artworks');
  return secondaryLocales.flatMap((lang) =>
    artworks.map((artwork) => ({
      params: { lang, slug: artwork.id },
      props: { artwork },
    }))
  );
}

const { artwork } = Astro.props;
const lang = Astro.params.lang as Locale;
---

<ArtworkDetail locale={lang} artwork={artwork} />
