---
import ArtistPage from '../../components/pages/ArtistPage.astro';
import { secondaryLocales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return secondaryLocales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
---

<ArtistPage locale={lang} />
