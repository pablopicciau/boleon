---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import '../styles/global.css';
import { isAvailable, isBaseAvailable, printFormatsFor, sortArtworks } from '../lib/artworks';
import settings from '../lib/settings';

// Pannello privato dell'artista: galleria cliccabile che apre la scheda
// di modifica in Keystatic. Non è linkato dal sito pubblico.
const artworks = sortArtworks(await getCollection('artworks'));
const artCollections = (await getCollection('collections')).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder || a.data.name.localeCompare(b.data.name)
);
const collectionName = new Map(artCollections.map((c) => [c.id, c.data.name]));
const collectionCounts = new Map(
  artCollections.map((c) => [c.id, artworks.filter((a) => a.data.collections.includes(c.id)).length])
);

const rows = artworks.map((a) => {
  const printFormats = printFormatsFor(a);
  const badges: { text: string; tone: 'ok' | 'warn' | 'muted' }[] = [];
  if (a.data.kind === 'original') {
    badges.push(
      a.data.sold
        ? { text: 'Originale venduto', tone: 'warn' }
        : { text: 'Originale disponibile', tone: 'ok' }
    );
  } else {
    badges.push(
      isBaseAvailable(a)
        ? { text: `Stampa base · ${a.data.stock ?? 0} copie`, tone: 'ok' }
        : { text: 'Stampa base esaurita', tone: 'warn' }
    );
  }
  if (printFormats.length > 0) {
    const pct = a.data.printPricePercent ?? 0;
    badges.push({
      text: `Stampe: ${printFormats.length} ${printFormats.length === 1 ? 'formato' : 'formati'}${pct ? ` · +${pct}%` : ''}`,
      tone: 'ok',
    });
  } else {
    badges.push({ text: 'Stampe non in vendita', tone: 'warn' });
  }
  if (a.data.bestseller) {
    badges.push({ text: '★ Più venduti', tone: 'muted' });
  }
  for (const c of a.data.collections) {
    badges.push({ text: collectionName.get(c) ?? c, tone: 'muted' });
  }
  const kindFilter = a.data.kind === 'original' && printFormats.length > 0 ? 'both' : a.data.kind;
  return { artwork: a, kindFilter, available: isAvailable(a), badges };
});

const toneClass = {
  ok: 'bg-neutral-100 text-neutral-700',
  warn: 'bg-accent/10 text-accent',
  muted: 'bg-neutral-100 text-neutral-500',
};
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Gestione opere — {settings.artistName}</title>
  </head>
  <body class="min-h-screen antialiased">
    <header class="border-b border-neutral-200 bg-white/70">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-5 py-5">
        <div>
          <p class="font-serif text-2xl font-semibold tracking-[0.25em] uppercase">{settings.artistName}</p>
          <p class="mt-0.5 text-xs tracking-[0.2em] uppercase opacity-50">Gestione opere</p>
        </div>
        <nav class="flex flex-wrap items-center gap-3 text-xs">
          <a
            href="/keystatic/collection/artworks/create"
            class="bg-accent px-4 py-2.5 font-medium tracking-[0.15em] text-white uppercase transition-colors hover:bg-[#6f1f33]"
          >
            + Nuova opera
          </a>
          <a
            href="/keystatic"
            class="border border-neutral-300 px-4 py-2.5 tracking-[0.15em] uppercase transition hover:border-ink"
          >
            Apri Keystatic
          </a>
          <a href="/" class="px-2 py-2.5 tracking-[0.15em] uppercase opacity-60 transition hover:opacity-100">
            Vedi il sito →
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-5 py-10">
      <p class="max-w-2xl text-sm leading-relaxed opacity-70">
        Clicca su un'opera per aprirla direttamente in Keystatic e modificarla: prezzi, misure,
        copie disponibili, foto e descrizioni.
      </p>

      <div class="mt-8 flex flex-wrap gap-2" data-filters>
        <button data-filter="all" class="chip chip-active">Tutte</button>
        <button data-filter="original">Con originale</button>
        <button data-filter="print">Con stampe</button>
        <button data-filter="unavailable">Vendute / esaurite</button>
      </div>

      <div class="mt-8 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3" data-grid>
        {
          rows.map(({ artwork, kindFilter, available, badges }) => (
            <a
              href={`/keystatic/collection/artworks/item/${artwork.id}`}
              class="group block"
              data-kind={kindFilter}
              data-available={available ? '1' : '0'}
            >
              <div class="relative overflow-hidden bg-neutral-100">
                <Image
                  src={artwork.data.images[0]}
                  alt={artwork.data.title}
                  width={600}
                  class="aspect-4/5 w-full object-cover transition duration-500 group-hover:scale-[1.02] group-hover:opacity-90"
                />
                <span class="absolute inset-x-0 bottom-0 flex items-center justify-center gap-1.5 bg-ink/85 py-2.5 text-[0.65rem] tracking-[0.2em] text-white uppercase opacity-0 transition group-hover:opacity-100">
                  ✎ Modifica
                </span>
              </div>
              <div class="mt-3 flex items-baseline justify-between gap-3">
                <h2 class="font-serif text-xl leading-snug font-medium">{artwork.data.title}</h2>
              </div>
              <div class="mt-2 flex flex-wrap gap-1.5">
                {badges.map((b) => (
                  <span class={`px-2 py-0.5 text-[0.7rem] ${toneClass[b.tone]}`}>{b.text}</span>
                ))}
              </div>
            </a>
          ))
        }
      </div>

      <div class="mt-16 flex flex-wrap items-baseline justify-between gap-4 border-t border-neutral-200 pt-10">
        <h2 class="text-xs font-semibold tracking-[0.25em] uppercase opacity-60">Collezioni</h2>
        <a
          href="/keystatic/collection/collections/create"
          class="bg-ink px-4 py-2 text-xs font-medium tracking-[0.15em] text-white uppercase transition-colors hover:bg-accent"
        >
          + Nuova collezione
        </a>
      </div>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed opacity-70">
        Le collezioni sono le sottosezioni della pagina <a href="/galleria" class="underline underline-offset-4">Galleria</a> del sito.
        Per assegnare un'opera a una collezione, apri l'opera e usa il campo "Collezioni".
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          artCollections.map((c) => (
            <a
              href={`/keystatic/collection/collections/item/${c.id}`}
              class="group border border-neutral-200 bg-white/60 p-5 transition hover:border-ink"
            >
              <p class="font-serif text-lg font-medium">{c.data.name}</p>
              <p class="mt-1.5 text-xs opacity-60">
                {collectionCounts.get(c.id) ?? 0}{' '}
                {(collectionCounts.get(c.id) ?? 0) === 1 ? 'opera' : 'opere'}
              </p>
              <p class="mt-3 text-[0.65rem] tracking-[0.2em] uppercase opacity-50 transition group-hover:opacity-100">
                ✎ Modifica →
              </p>
            </a>
          ))
        }
      </div>

      <h2 class="mt-16 border-t border-neutral-200 pt-10 text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
        Il resto del sito
      </h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            {
              href: '/keystatic/singleton/identity',
              title: 'Nome e testi',
              desc: 'Nome artista, tagline, biografia e la storia della pagina "L\'artista".',
            },
            {
              href: '/keystatic/singleton/cover',
              title: 'Sfondi della copertina',
              desc: 'Le immagini a rotazione della schermata iniziale.',
            },
            {
              href: '/keystatic/singleton/contacts',
              title: 'Contatti e social',
              desc: 'Email di contatto, Instagram e Facebook.',
            },
            {
              href: '/keystatic/singleton/shop',
              title: 'Vendita e stampe',
              desc: 'Il testo sui materiali mostrato sotto i formati di stampa.',
            },
          ].map((s) => (
            <a
              href={s.href}
              class="group border border-neutral-200 bg-white/60 p-5 transition hover:border-ink"
            >
              <p class="font-serif text-lg font-medium">{s.title}</p>
              <p class="mt-1.5 text-xs leading-relaxed opacity-60">{s.desc}</p>
              <p class="mt-3 text-[0.65rem] tracking-[0.2em] uppercase opacity-50 transition group-hover:opacity-100">
                ✎ Modifica →
              </p>
            </a>
          ))
        }
      </div>

      <h2 class="mt-14 text-xs font-semibold tracking-[0.25em] uppercase opacity-60">
        Collegamenti utili
      </h2>
      <div class="mt-4 flex flex-wrap gap-x-8 gap-y-2 text-sm">
        <a href="https://dashboard.stripe.com" target="_blank" rel="noopener" class="underline-offset-4 hover:underline">
          Stripe — ordini e pagamenti ↗
        </a>
        <a href="https://dash.cloudflare.com" target="_blank" rel="noopener" class="underline-offset-4 hover:underline">
          Cloudflare — hosting e dominio ↗
        </a>
        <a href="https://github.com/pablopicciau/boleon" target="_blank" rel="noopener" class="underline-offset-4 hover:underline">
          GitHub — archivio del sito ↗
        </a>
        <a href="https://resend.com" target="_blank" rel="noopener" class="underline-offset-4 hover:underline">
          Resend — email di notifica ↗
        </a>
      </div>
    </main>

    <style>
      [data-filters] button {
        border: 1px solid var(--color-neutral-300);
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        background: transparent;
      }
      [data-filters] button:hover {
        border-color: var(--color-ink);
      }
      [data-filters] button.chip-active {
        background: var(--color-ink);
        border-color: var(--color-ink);
        color: #fff;
      }
    </style>

    <script>
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filters] button');
      const cards = document.querySelectorAll<HTMLElement>('[data-grid] > a');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => b.classList.toggle('chip-active', b === btn));
          const filter = btn.dataset.filter;
          cards.forEach((card) => {
            const kind = card.dataset.kind;
            const available = card.dataset.available === '1';
            const show =
              filter === 'all' ||
              (filter === 'original' && (kind === 'original' || kind === 'both')) ||
              (filter === 'print' && (kind === 'print' || kind === 'both')) ||
              (filter === 'unavailable' && !available);
            card.classList.toggle('hidden', !show);
          });
        });
      });
    </script>
  </body>
</html>
